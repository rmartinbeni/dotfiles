#!/bin/bash
set -euo pipefail

SETUP_COMMIT_GPG=$(echo "$SETUP_COMMIT_GPG" | tr '[:upper:]' '[:lower:]')
if [[ "$SETUP_COMMIT_GPG" != "true" ]]; then
  echo "❌ GPG setup is disabled. Skipping."
  exit 0
fi

NAME="{{ .git_name }}"
EMAIL="{{ .git_email }}"
EXPIRE_DATE="0"

command -v gpg >/dev/null 2>&1 || { echo "❌ GPG not installed. Aborting." >&2; exit 1; }

KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" 2>/dev/null | awk -F: '/^fpr/{print $10; exit}' || true)

if [[ -n "$KEY_ID" ]]; then
  echo "⚠️ A GPG key already exists for $EMAIL. Skipping key generation."
else
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT

  cat >"$tmp" <<EOF
%no-protection
Key-Type: eddsa
Key-Curve: ed25519
Subkey-Type: ecdh
Subkey-Curve: cv25519
Name-Real: $NAME
Name-Email: $EMAIL
Expire-Date: $EXPIRE_DATE
%commit
EOF

  echo "🔐 Generating GPG ed25519 key..."
  gpg --batch --generate-key "$tmp"
  KEY_ID=$(gpg --list-secret-keys --with-colons "$EMAIL" | awk -F: '/^fpr/{print $10; exit}')
  [[ -z "$KEY_ID" ]] && { echo "❌ Could not obtain key ID." >&2; exit 1; }
  echo "✅ Key generated with ID: $KEY_ID"
fi

if [[ "$(git config --global --get user.signingkey || true)" != "$KEY_ID" ]]; then
  echo "⚙️ Configuring Git..."
  git config --global user.signingkey "$KEY_ID"
  git config --global commit.gpgsign true
  echo "✅ Git configured with key ID: $KEY_ID"
else
  echo "⚠️ GPG key is already configured in Git. Skipping Git configuration."
fi

CHEZMOI_FILE="$HOME/.config/chezmoi/chezmoi.toml"
if ! grep -q "key = \"$KEY_ID\"" "$CHEZMOI_FILE"; then
  echo -e "\n[gpg]\n  key = \"$KEY_ID\"" >> "$CHEZMOI_FILE"
  echo "➕ Added [gpg] section with key in $CHEZMOI_FILE."
  sed -i -E "s|^\s*git_gpgkey\s*=.*$|  git_gpgkey = \"$KEY_ID\"|" "$CHEZMOI_FILE"
  echo "➕ Inserted git_gpgkey in existing [data] section of $CHEZMOI_FILE"
else
  echo "⚠️ GPG key is already present in $CHEZMOI_FILE. Skipping addition."
fi

echo "📋 Public key (copy and paste this into GitHub/GitLab):"
gpg --armor --export "$KEY_ID"
