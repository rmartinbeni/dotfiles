theme = Espresso
font-size = 20
font-family = FiraCode Nerd Font Mono

# --- Window Appearance ---
window-padding-x = 10
window-padding-y = 10
window-theme = ghostty
macos-titlebar-style = transparent

# --- Transparency & Blur ---
background-opacity = 0.85
background-blur-radius = 20

# --- Cursor & Mouse Tweaks ---
mouse-hide-while-typing = true
cursor-style = block
cursor-style-blink = true