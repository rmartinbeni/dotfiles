#!/bin/bash
set -euo pipefail

# This script ensures NVM is installed before continuing.
export NVM_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/nvm"

if [ ! -s "$NVM_DIR/nvm.sh" ]; then
  echo "📦 Installing NVM..."
  mkdir -p "$NVM_DIR"
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | NVM_DIR="$NVM_DIR" bash
else
  echo "✅ NVM is already installed at $NVM_DIR"
fi

# Ensure NVM can be loaded directly for the subsequent node install script
export NVM_DIR="$NVM_DIR"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
