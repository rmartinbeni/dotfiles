#!/bin/bash
set -e

export NVM_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/nvm"

if [ -s "$NVM_DIR/nvm.sh" ]; then
  source "$NVM_DIR/nvm.sh"
else
  # Attempt direct install via curl as fallback if NVM directory exists but not populated yet
  export NVM_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/nvm"
  mkdir -p "$NVM_DIR"
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | NVM_DIR="$NVM_DIR" bash
  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh" || { echo "❌ NVM not found. Cannot install Node."; exit 1; }
fi

echo "📦 Installing latest Node.js via NVM..."
nvm install node
nvm alias default node

echo "📦 Installing global npm packages..."
npm install -g @google/genai eslint prettier typescript
echo "✅ Node and global packages installed!"
